{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2020",
    "skipLibCheck": true,
    "strict": false,
    "noEmitOnError": false,
    "rootDir": "../src",
    "outDir": "../dist/types"
  },
  "include": ["../src/index.js", "../src/ui/**/*.jsx", "../src/lib/**/*.js"]
}
